# ===========================================
# WhatShouldWeEat - Environment Configuration
# ===========================================
# Copy this file to .env.local for development
# or .env for production/Docker deployment

# -----------------
# Database Settings
# -----------------
# SQLite database path (relative to project root)
# For Docker: file:/app/data/recipes.db
DATABASE_URL=file:./data/recipes.db

# -----------------
# LLM Configuration
# -----------------
# Provider: claude, openai, or ollama
LLM_PROVIDER=claude

# Anthropic Claude API Key (required if using claude provider)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key (required if using openai provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama Configuration (required if using ollama provider)
# Base URL for your Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Specify a custom model
# Claude: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5
# OpenAI: gpt-4o, gpt-4o-mini
# Ollama: llama3.2-vision (for image support), llama3.2, mistral, etc.
LLM_MODEL=

# -----------------
# Application Settings
# -----------------
# Port to run the application on (default: 3000)
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# -----------------
# Briefing API
# -----------------
# Shared secret for read-only access to /api/briefing/* routes
# (used by external agents like icculus). Generate with:
#   openssl rand -hex 32
# Leave blank to disable the briefing endpoints.
BRIEFING_API_KEY=
